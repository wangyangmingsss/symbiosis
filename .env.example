ESCROW_SETTLEMENT=0x_deployed_address
REPUTATION_ENGINE=0x_deployed_address
ECONOMY_ORACLE=0x_deployed_address
AGENT_TREASURY=0x_deployed_address

# --- Uniswap V3 (X Layer) ---
UNISWAP_ROUTER=0x_uniswap_v3_router_on_xlayer
UNISWAP_FACTORY=0x_uniswap_v3_factory_on_xlayer
WOKB_ADDRESS=0x_wrapped_okb_address
